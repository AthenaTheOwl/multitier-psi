{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mtpsi/supplier_graph.schema.json",
  "title": "supplier graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "party_id", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "party_id": {
      "type": "string",
      "minLength": 1
    },
    "dictionary_version": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "type", "display_name", "party_local_id"],
        "properties": {
          "node_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "brand",
              "tier1_supplier",
              "tier2_supplier",
              "tier3_supplier",
              "component"
            ]
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "party_local_id": {
            "type": "string",
            "minLength": 1
          },
          "canonical_id": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "type"],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": ["sources_from", "depends_on"]
          }
        }
      }
    }
  }
}
